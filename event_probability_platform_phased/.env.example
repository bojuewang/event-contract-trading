# Core
ENV=dev
DATABASE_URL=postgresql+psycopg://prob:prob@localhost:5432/probability
REDIS_URL=redis://localhost:6379/0

# The Odds API
ODDS_API_KEY=replace_me
ODDS_API_SPORT=basketball_nba
ODDS_API_REGIONS=us
ODDS_API_MARKETS=h2h
ODDS_API_ODDS_FORMAT=decimal
ODDS_API_POLL_SECONDS=5

# Polymarket public APIs
POLYMARKET_GAMMA_BASE=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE=https://clob.polymarket.com

# Kalshi requires authenticated websocket / API credentials
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# Model defaults
MODEL_REFRESH_MS=1000
MONTE_CARLO_PATHS=20000
DEFAULT_VOL_PER_SQRT_MIN=0.045
DEFAULT_MEAN_REVERSION=0.05
